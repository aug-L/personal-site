---
// layout
import Layout from "../../layout/Layout.astro";

// components
import Section from "../../components/elements/Section.astro";
import ProjectCard from "../../components/elements/ProjectCard.astro";
import Pagination from "../../components/elements/Pagination.astro";

// routing
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
export const getStaticPaths = (async ({ paginate }) => {
  const projects = (
    await getCollection("projects", ({ data }) => !data.isDraft)
  ).sort(
    (a, b) =>
      b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
  );
  return paginate(projects, { pageSize: 3 });
}) satisfies GetStaticPaths;

// props
const { page } = Astro.props;
---

<Layout
  title="All Projects"
  description="All projects for software engineer"
  ogImage=""
>
  <Section
    title="All Projects"
    titleHeading="All the things I've built, broken and experimented with"
  >
    {
      page.data.map((project) => (
        <ProjectCard
          title={project.data.title}
          year={project.data.year}
          git={project.data.git}
          website={project.data.liveSite}
          playStore={project.data.playStore}
          appStore={project.data.appStore}
          fdroid={project.data.fdroid}
          apk={project.data.apk}
          description={project.data.description}
          tools={project.data.tools}
        />
      ))
    }
    <Pagination prev={page.url.prev} next={page.url.next} />
  </Section>
</Layout>
