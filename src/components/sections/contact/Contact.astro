---
// components
import Section from "../../elements/Section.astro";
import Text from "../../elements/Text.astro";
import Link from "../../elements/Link.astro";
import SocialLinks from "../../elements/SocialLinks.astro";

const EMAIL_ADDRESS_WORK = "auglam.lch@gmail.com";
const EMAIL_ADDRESS_PERSONAL = "chlam.ghpfo7uj@pm.me";
---

<Section aria-label="Contact" title="Contact" titleHeading="">
  <div class="flex flex-col gap-16 text-base-300">
    <Text variant={"normal"}
      >For work:
      <Link
        variant={"inline"}
        href={"mailto:" + [EMAIL_ADDRESS_WORK]}
        text={EMAIL_ADDRESS_WORK}
      />
      <br />For personal matters:
      <Link
        variant={"inline"}
        href={"mailto:" + [EMAIL_ADDRESS_PERSONAL]}
        text={EMAIL_ADDRESS_PERSONAL}
      />
    </Text>
    <Text variant={"normal"}
      >You can also find me online or send a message through any of these
      platforms:</Text
    >
  </div>
  <SocialLinks includeEmail={false} />
</Section>
