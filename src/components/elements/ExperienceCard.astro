---
// assets
import Calendar from "../../assets/icons/Calendar.astro";

// components
import Text from "../elements/Text.astro";
import Heading from "../elements/Heading.astro";

const experience = Astro.props;
---

<div class="border-2 border-base-900">
  <div class="bg-base-900 p-16 flex flex-col gap-16">
    <Heading tagName="h3" tagSize="h3">
      {experience.title}
      {experience.company && <span> - {experience.company}</span>}
    </Heading>
    <div class="flex flex-row gap-32">
      <div class="flex flex-row gap-8 text-base-100 items-center">
        <Calendar width={20} height={20} fill="currentColor" />
        <Text variant={"sm"} class="text-base-500"
          >{experience.from} - {experience.to}</Text
        >
      </div>
    </div>
    <!-- TODO add tags here -->
  </div>
  {
    experience.desc ? (
      <div class="p-16">
        <Text variant={"normal"} class="text-base-300">
          {experience.desc}
        </Text>
      </div>
    ) : (
      ""
    )
  }
</div>
