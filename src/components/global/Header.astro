---
import photo from "../../assets/images/blinq-qr.jpg"; // change to your image

// components
import Text from "../elements/Text.astro";
import NavBar from "./NavBar.astro";
import SocialLinks from "../elements/SocialLinks.astro";

// header content -> modify here!
const {
  role = "Full-Stack Software Developer",
  name = "Chunhin Lam",
  status = "Available for work",
} = Astro.props;
---

<header
  class="flex flex-col gap-16 md:pt-8 pt-16 bg-base-950 md:sticky md:top-0 z-50"
>
  <div class="md:px-32 px-16 flex md:flex-row flex-col gap-16 items-center">
    <img
      src={photo.src}
      alt="Business card"
      width={200}
      height={200}
      loading="eager"
      class="object-cover object-center w-25 h-25 sepia-50 drop-shadow-md"
    />

    <div
      class="flex md:flex-row flex-col gap-16 justify-between items-center w-full"
    >
      <div
        class="flex flex-col gap-16 md:items-start justify-center items-center"
      >
        <div class="flex flex-col md:text-left text-center">
          <Text variant={"normal"} class="text-base-700">// {role}</Text>
          <Text variant={"xl"}>{name}</Text>
        </div>
        <SocialLinks includeEmail={true} />
      </div>
      <!-- <div class="bg-base-950 drop-shadow-md p-8">
        <Text variant={"sm"} class="text-base-200">{status}</Text>
      </div> -->
    </div>
  </div>
  <NavBar />
</header>
